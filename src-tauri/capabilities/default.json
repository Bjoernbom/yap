{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema/capability.json",
	"identifier": "default",
	"description": "Default permissions for Voice Thing",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"sql:default",
		"sql:allow-execute",
		"sql:allow-select",
		"fs:default",
		"fs:allow-read",
		"fs:allow-write",
		"fs:allow-exists",
		"fs:allow-mkdir",
		"shell:default",
		"global-shortcut:default",
		"global-shortcut:allow-register"
	]
}
