{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema/capability.json",
	"identifier": "default",
	"description": "Default permissions for Voice Thing",
	"windows": ["main", "overlay"],
	"permissions": [
		"core:default",
		"core:tray:default",
		"core:tray:allow-new",
		"core:tray:allow-set-icon",
		"core:tray:allow-set-icon-as-template",
		"core:tray:allow-set-tooltip",
		"core:menu:default",
		"core:menu:allow-new",
		"core:menu:allow-popup",
		"core:menu:allow-set-text",
		"core:menu:allow-set-enabled",
		"core:event:default",
		"core:event:allow-emit",
		"core:event:allow-listen",
		"core:window:default",
		"core:window:allow-show",
		"core:window:allow-hide",
		"core:window:allow-set-focus",
		"core:window:allow-create",
		"core:window:allow-center",
		"core:window:allow-set-always-on-top",
		"core:window:allow-set-size",
		"core:window:allow-set-position",
		"core:window:allow-is-visible",
		"core:window:allow-start-dragging",
		"sql:default",
		"sql:allow-execute",
		"sql:allow-select",
		"fs:default",
		"fs:allow-read",
		"fs:allow-write",
		"fs:allow-exists",
		"fs:allow-mkdir",
		"fs:allow-remove",
		"fs:scope-appdata-recursive",
		"shell:default",
		"process:default",
		"process:allow-exit",
		"autostart:default"
	]
}
