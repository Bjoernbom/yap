{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "Voice Thing",
	"version": "0.1.0",
	"identifier": "com.voicething.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build"
	},
	"app": {
		"windows": [
			{
				"title": "voice thing",
				"width": 900,
				"height": 700,
				"minWidth": 600,
				"minHeight": 500,
				"resizable": true,
				"decorations": true,
				"transparent": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"resources": [
			"icons/icon.png",
			"icons/icon-recording.png"
		],
		"macOS": {
			"infoPlist": "Info.plist"
		}
	},
	"plugins": {
		"sql": {
			"preload": [
				"sqlite:voice-thing.db"
			]
		}
	}
}
