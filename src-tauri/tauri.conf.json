{
	"$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
	"productName": "yap",
	"version": "0.2.0",
	"identifier": "com.voicething.app",
	"build": {
		"frontendDist": "../dist",
		"devUrl": "http://localhost:1420",
		"beforeDevCommand": "bun run dev",
		"beforeBuildCommand": "bun run build"
	},
	"app": {
		"windows": [
			{
				"title": "yap",
				"width": 380,
				"height": 560,
				"minWidth": 320,
				"minHeight": 400,
				"resizable": true,
				"decorations": true,
				"transparent": false,
				"hiddenTitle": true,
				"titleBarStyle": "Overlay"
			}
		],
		"security": {
			"csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; connect-src 'self' https://api.github.com"
		},
		"trayIcon": {
			"id": "yap-tray",
			"iconPath": "icons/tray-icon.png",
			"iconAsTemplate": true,
			"tooltip": "yap"
		}
	},
	"bundle": {
		"resources": [
			"icons/tray-icon.png",
			"icons/tray-recording.png"
		],
		"icon": [
			"icons/icon.icns",
			"icons/icon.png",
			"icons/128x128.png",
			"icons/32x32.png"
		],
		"macOS": {
			"infoPlist": "Info.plist"
		}
	},
	"plugins": {
		"sql": {
			"preload": [
				"sqlite:voice-thing.db"
			]
		}
	}
}
